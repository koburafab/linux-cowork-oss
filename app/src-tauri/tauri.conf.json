{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "linux-cowork",
  "version": "0.1.0",
  "identifier": "ch.ethernity.linux-cowork",
  "mainBinaryName": "linux-cowork",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bunx --bun vite",
    "beforeBuildCommand": "bunx --bun vite build"
  },
  "app": {
    "windows": [
      {
        "title": "Linux Cowork OSS",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/cowork-backend"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
